# ═══════════════════════════════════════════════════════════════
# RedTrace — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and adjust values for your setup.
# All variables are optional — defaults are shown below.
# ═══════════════════════════════════════════════════════════════

# ── PyRIT Attacker LLM ────────────────────────────────────────
# The LLM that generates adversarial prompts (plays the attacker role).
# PYRIT_ATTACKER_ENDPOINT=http://127.0.0.1:11434/v1
# PYRIT_ATTACKER_MODEL=gemma4:e4b
# PYRIT_ATTACKER_API_KEY=ollama

# ── PyRIT Scorer LLM ─────────────────────────────────────────
# The LLM that evaluates target responses (JSON structured output).
# Falls back to ATTACKER values if not set.
# Tip: use a model good at structured JSON (e.g. gpt-4o, llama3.1:8b).
# PYRIT_SCORER_ENDPOINT=http://127.0.0.1:11434/v1
# PYRIT_SCORER_MODEL=gemma4:e4b
# PYRIT_SCORER_API_KEY=ollama

# ── PyRIT Runtime ─────────────────────────────────────────────
# PYRIT_DB_PATH=~/Library/Application Support/dbdata/pyrit.db
# PYRIT_LOOP_SHUTDOWN_DELAY=0.3
# PYRIT_DATASET_MAX_CONCURRENCY=5

# ── Target ────────────────────────────────────────────────────
# DEFAULT_TARGET_URL=http://localhost:8000/api/chat

# ── Reports ───────────────────────────────────────────────────
# JSON_REPORTS_DIR=reports

# ── Garak ─────────────────────────────────────────────────────
# GARAK_REPORTS_DIR=~/.local/share/garak/garak_runs/reports
# GARAK_CONFIG_PATH=configs/garak_config.json
# GARAK_PYTHON_EXECUTABLE=python
# GARAK_REQUEST_TIMEOUT=60
# GARAK_DEFAULT_REPORT_PREFIX=reports/run

